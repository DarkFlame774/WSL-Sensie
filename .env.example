# ── WSL Sensei – Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Endee Vector Database ─────────────────────────────────────────────────────
ENDEE_BASE_URL=http://localhost:8080/api/v1
ENDEE_AUTH_TOKEN=          # Leave empty if running without authentication
ENDEE_INDEX_NAME=wsl_sensei

# ── Embedding Model (local, no API key required) ──────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | mock
LLM_BACKEND=ollama

# Ollama (free, local) – recommended for development
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# OpenAI (paid cloud)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (paid cloud)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=6
RAG_MAX_TOKENS=1024

# ── Custom Paths (optional – defaults shown) ──────────────────────────────────
# BASH_HISTORY_PATH=~/.bash_history
# PS_HISTORY_PATH=~/AppData/Roaming/Microsoft/Windows/PowerShell/PSReadLine/ConsoleHost_history.txt
# CONFIG_SCAN_PATHS=~/.bashrc,~/.zshrc,~/.profile,~/.gitconfig,~/.ssh/config
# CONFIG_SCAN_EXTENSIONS=.conf,.cfg,.yml,.yaml,.toml,.ini,.env,.sh,.ps1,.md
# MAX_SCAN_DEPTH=3
